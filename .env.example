# ─── WHV Tax CRM — Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. NEVER commit .env.local to git.

# ─── Vercel Postgres (REQUIRED for data persistence) ─────────────────────
# Set automatically when you add Postgres to your Vercel project
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=whvtax-crm-secret-2024-changeme
CRM_PASSWORD=your_password_here
PASSWORD_SALT=whvtax-salt-2024

# ─── Resend (email alerts) ────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CRM_ADMIN_EMAIL=your@email.com

# ─── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://workingholidaytax.com.au
