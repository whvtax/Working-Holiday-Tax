# ─── Working Holiday Tax — Environment Variables ────────────────────────────
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.

# ─── Resend (Email) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── CRM Admin ────────────────────────────────────────────────────────────
# The email address where OTP codes and security alerts are sent
CRM_ADMIN_EMAIL=your@email.com

# Hashed admin password. Generate with:
# node -e "const c=require('crypto'); console.log(c.pbkdf2Sync('YOUR_PASSWORD','whvtax-salt-2024',100000,64,'sha512').toString('hex'))"
# Default dev password (CHANGE IN PRODUCTION): WHVAdmin2024!
CRM_PASSWORD_HASH=

# Salt for password hashing (change to a random string in production)
PASSWORD_SALT=whvtax-salt-2024

# ─── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://workingholidaytax.com.au
