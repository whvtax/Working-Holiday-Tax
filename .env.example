# ─── WHV Tax CRM — Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. NEVER commit .env.local to git.

# Resend — for security alert emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Admin email — security alerts sent here
CRM_ADMIN_EMAIL=your@email.com

# CRM password hash (generate: node -e "const c=require('crypto'); console.log(c.pbkdf2Sync('YOUR_PASSWORD','whvtax-salt-2024',100000,64,'sha512').toString('hex'))")
CRM_PASSWORD_HASH=

# Salt for password hashing
PASSWORD_SALT=whvtax-salt-2024

# JWT secret — REQUIRED on Vercel to keep sessions alive across instances
# Generate a random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=whvtax-crm-secret-2024-changeme

# Site URL
NEXT_PUBLIC_SITE_URL=https://workingholidaytax.com.au
