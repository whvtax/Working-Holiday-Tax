# ─── WHV Tax CRM — Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values. NEVER commit .env.local to git.

# ─── Vercel Postgres (REQUIRED for data persistence) ─────────────────────
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Auth ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
# Your chosen CRM login password
CRM_PASSWORD=
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PASSWORD_SALT=

# ─── Resend (email alerts + OTP) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CRM_ADMIN_EMAIL=your@email.com

# ─── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://workingholidaytax.com.au

# ─── Redis (Upstash/Vercel) — REQUIRED for OTP + rate limiting + session revocation ──
# Set automatically when you connect Redis in Vercel Storage
REDIS_URL=

# ─── Seed (development only) ─────────────────────────────────────────────
# Must be set to "true" to enable /api/crm/seed endpoint (only works in non-production)
# ENABLE_SEED=true
