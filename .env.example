# ─── WHV Tax CRM — Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in ALL values. NEVER commit .env.local to git.
# The app will throw an error at startup if any required variable is missing.

# ─── Vercel Postgres (REQUIRED for data persistence) ─────────────────────
# Set automatically when you add Postgres to your Vercel project
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ─── Auth (REQUIRED — generate strong random values) ─────────────────────
# JWT_SECRET:      run:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# CRM_PASSWORD:    choose a strong password (min 16 chars, mixed case + symbols)
# PASSWORD_SALT:   run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
CRM_PASSWORD=
PASSWORD_SALT=

# ─── Reviewer portal (REQUIRED if using the reviewer role) ────────────────
# REVIEWER_SALT:          run:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REVIEWER_PASSWORD_HASH: generate with the hash-reviewer-password script after setting REVIEWER_SALT
#   e.g.  node -e "const c=require('crypto'); console.log(c.pbkdf2Sync('YOUR_REVIEWER_PASSWORD', process.env.REVIEWER_SALT+'_reviewer', 100000, 64, 'sha512').toString('hex'))"
REVIEWER_SALT=
REVIEWER_PASSWORD_HASH=

# ─── Resend (email alerts + OTP delivery) ────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
CRM_ADMIN_EMAIL=your@email.com

# ─── Site ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://workingholidaytax.com.au

# ─── Vercel Blob (REQUIRED for file uploads — selfie, bank statement, etc.) ─
# Set automatically when you add Blob storage to your Vercel project
BLOB_READ_WRITE_TOKEN=

# ─── Redis (Upstash/Vercel) — REQUIRED for OTP + brute-force protection ──
# Set automatically when you connect Redis in Vercel Storage
REDIS_URL=

# ─── Dev/Staging only ─────────────────────────────────────────────────────
# Set to 'true' ONLY in dev/staging to enable the /api/crm/seed endpoint.
# NEVER set this in production.
# SEED_ENABLED=true
